{
    "name": "dandoetech/laravel-openapi-generator",
    "description": "Laravel bridge for DanDoeTech OpenAPI generator: artisan export command and wiring.",
    "type": "library",
    "license": "MIT",
    "authors": [{ "name": "Danilo Doelle", "email": "oss@dandoe.tech" }],
    "homepage": "https://github.com/dandoe-tech/laravel-openapi-generator",
    "keywords": ["php", "laravel", "openapi", "swagger", "artisan"],
    "require": {
        "php": "^8.2 || ^8.3 || ^8.4",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0",
        "illuminate/console": "^10.0 || ^11.0 || ^12.0",
        "illuminate/contracts": "^10.0 || ^11.0 || ^12.0",
        "illuminate/filesystem": "^10.0 || ^11.0 || ^12.0",
        "dandoetech/openapi-generator": "^0.1",
        "dandoetech/resource-registry": "^0.1",
        "dandoetech/laravel-resource-registry": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0"
    },
    "autoload": {
        "psr-4": { "DanDoeTech\\LaravelOpenApiGenerator\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": {
            "DanDoeTech\\LaravelOpenApiGenerator\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "XDEBUG_MODE=off phpunit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-text --coverage-clover=coverage/clover.xml",
        "cs:fix": "php-cs-fixer fix --allow-risky=yes",
        "cs:check": "php-cs-fixer fix --allow-risky=yes --dry-run",
        "stan": "phpstan analyse --memory-limit=1G",
        "qa": [
            "@cs:check",
            "@stan",
            "@test"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "laravel": {
            "providers": [
                "DanDoeTech\\LaravelOpenApiGenerator\\Providers\\OpenApiServiceProvider"
            ]
        }
    }
}
